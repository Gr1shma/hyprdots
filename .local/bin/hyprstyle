#!/bin/bash

# Configuration
WALLPAPER_DIR=~/pix/wallpaper
MONITOR="eDP-1"
WALLPAPER="$1"

# Expand tilde in wallpaper directory
WALLPAPER_DIR="${WALLPAPER_DIR/#\~/$HOME}"

# Logging function
log() {
    echo "[$(date '+%H:%M:%S')] $1"
}

start_hyprpaper() {
    if ! pgrep -x "hyprpaper" >/dev/null 2>&1; then
        log "Hyprpaper is not running. Waiting for it to start..."

        # Wait up to 10 seconds for hyprpaper to start
        for i in {1..10}; do
            sleep 1
            if pgrep -x "hyprpaper" >/dev/null 2>&1; then
                log "Hyprpaper detected (waited ${i}s)"
                return 0
            fi
        done

        log "Hyprpaper still not running after 10s. Starting it manually..."
        if command -v hyprpaper &>/dev/null; then
            hyprpaper &>/dev/null &
            sleep 3
            if ! pgrep -x "hyprpaper" >/dev/null 2>&1; then
                log "Error: Failed to start hyprpaper"
                exit 1
            fi
            log "Hyprpaper started successfully"
        else
            log "Error: hyprpaper command not found"
            exit 1
        fi
    else
        log "Hyprpaper is already running"
    fi
}

choose_random_wallpaper() {
    log "No wallpaper specified. Picking a random one from $WALLPAPER_DIR..."

    if [[ ! -d $WALLPAPER_DIR ]]; then
        log "Error: Wallpaper directory does not exist: $WALLPAPER_DIR"
        exit 1
    fi

    # Use an array to handle filenames with spaces
    mapfile -t wallpapers < <(find "$WALLPAPER_DIR" -type f \( -iname '*.jpg' -o -iname '*.png' -o -iname '*.jpeg' -o -iname '*.bmp' -o -iname '*.webp' -o -iname '*.gif' \) 2>/dev/null)

    if [[ ${#wallpapers[@]} -eq 0 ]]; then
        log "Error: No wallpapers found in $WALLPAPER_DIR"
        exit 1
    fi

    # Get random wallpaper
    WALLPAPER="${wallpapers[RANDOM % ${#wallpapers[@]}]}"
    log "Selected random wallpaper: $(basename "$WALLPAPER")"
}

resolve_wallpaper_path() {
    local input="$1"

    # Handle empty input
    if [[ -z $input ]]; then
        echo ""
        return 1
    fi

    # If it's already an absolute path and exists, use it
    if [[ $input == /* ]] && [[ -f $input ]]; then
        echo "$input"
        return 0
    fi

    # If it's a relative path from current directory, try to resolve it
    if [[ -f $input ]]; then
        realpath "$input" 2>/dev/null || echo "$input"
        return 0
    fi

    # Try looking in the wallpaper directory
    if [[ -f "$WALLPAPER_DIR/$input" ]]; then
        echo "$WALLPAPER_DIR/$input"
        return 0
    fi

    # Try with common extensions if no extension provided
    for ext in jpg png jpeg bmp webp gif; do
        if [[ -f "$WALLPAPER_DIR/$input.$ext" ]]; then
            echo "$WALLPAPER_DIR/$input.$ext"
            return 0
        fi
    done

    # If nothing found, return the original input
    echo "$input"
    return 1
}

set_wallpaper() {
    local wallpaper="$1"

    if [[ ! -f $wallpaper ]]; then
        log "Error: Wallpaper file not found -> $wallpaper"
        exit 1
    fi

    log "Applying wallpaper to monitor $MONITOR..."

    # Directly set wallpaper (hyprpaper handles loading internally)
    if ! hyprctl hyprpaper wallpaper "$MONITOR,$wallpaper,cover"; then
        log "Warning: Failed for $MONITOR, trying fallback"
        if ! hyprctl hyprpaper wallpaper ",$wallpaper,cover"; then
            log "Error: Failed to apply wallpaper"
            exit 1
        fi
    fi

    log "Wallpaper set successfully: $(basename "$wallpaper")"
}

apply_rmpc_theme() {
    local colors_file="$HOME/.cache/wal/colors.json"
    local rmpc_config_dir="$HOME/.config/rmpc"
    local rmpc_theme="$rmpc_config_dir/themes/theme.ron"

    if [[ ! -f $colors_file ]]; then
        log "Warning: colors.json not found. Cannot generate rmpc theme."
        return 1
    fi

    if ! command -v jq &>/dev/null; then
        log "Warning: jq not found. Cannot generate rmpc theme."
        return 1
    fi

    log "Generating rmpc theme from pywal colors..."

    mkdir -p "$rmpc_config_dir"

    # Extract colors
    local bg=$(jq -r '.special.background // empty' "$colors_file" 2>/dev/null)
    local fg=$(jq -r '.special.foreground // empty' "$colors_file" 2>/dev/null)
    local c0=$(jq -r '.colors.color0 // empty' "$colors_file" 2>/dev/null)
    local c1=$(jq -r '.colors.color1 // empty' "$colors_file" 2>/dev/null)
    local c2=$(jq -r '.colors.color2 // empty' "$colors_file" 2>/dev/null)
    local c3=$(jq -r '.colors.color3 // empty' "$colors_file" 2>/dev/null)
    local c4=$(jq -r '.colors.color4 // empty' "$colors_file" 2>/dev/null)
    local c6=$(jq -r '.colors.color6 // empty' "$colors_file" 2>/dev/null)
    local c8=$(jq -r '.colors.color8 // empty' "$colors_file" 2>/dev/null)

    if [[ -z $bg || -z $fg ]]; then
        log "Warning: Could not extract colors from colors.json"
        return 1
    fi

    # Generate rmpc theme
    cat >"$rmpc_theme" <<THEME
#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    default_album_art_path: None,
    draw_borders: false,
    show_song_table_header: false,
    symbols: (song: " ", dir: " ", marker: "> "),
    layout: Split(
        direction: Vertical,
        panes: [
            (
                pane: Pane(Header),
                size: "1",
            ),
            (
                pane: Pane(TabContent),
                size: "100%",
            ),
            (
                pane: Pane(ProgressBar),
                size: "1",
            ),
        ],
    ),
    progress_bar: (
        symbols: ["-", ">", " "],
        track_style: (bg: "${bg}"),
        elapsed_style: (fg: "${c1}", bg: "${bg}"),
        thumb_style: (fg: "${c1}", bg: "${bg}"),
    ),
    scrollbar: (
        symbols: ["│", "█", "▲", "▼"],
        track_style: (),
        ends_style: (),
        thumb_style: (fg: "${c4}"),
    ),
    browser_column_widths: [20, 38, 42],
    text_color: "${fg}",
    background_color: "${bg}",
    header_background_color: "${c0}",
    modal_background_color: None,
    tab_bar: (active_style: (fg: "${bg}", bg: "${c1}", modifiers: "Bold"), inactive_style: ()),
    borders_style: (fg: "${c8}"),
    highlighted_item_style: (fg: "${c1}", modifiers: "Bold"),
    current_item_style: (fg: "${bg}", bg: "${c4}", modifiers: "Bold"),
    highlight_border_style: (fg: "${c4}"),
    song_table_format: [
        (
            prop: (kind: Property(Artist), style: (fg: "${c4}"), default: (kind: Text("Unknown"))),
            width: "50%",
            alignment: Right,
        ),
        (
            prop: (kind: Text("-"), style: (fg: "${c4}"), default: (kind: Text("Unknown"))),
            width: "1",
            alignment: Center,
        ),
        (
            prop: (kind: Property(Title), style: (fg: "${c6}"), default: (kind: Text("Unknown"))),
            width: "50%",
        ),
    ],
    header: (
        rows: [
            (
                left: [
                    (kind: Text("["), style: (fg: "${c4}", modifiers: "Bold")),
                    (kind: Property(Status(State)), style: (fg: "${c4}", modifiers: "Bold")),
                    (kind: Text("]"), style: (fg: "${c4}", modifiers: "Bold")),
                    (kind: Text(" ["), style: (fg: "${c4}", modifiers: "Bold")),
                    (kind: Text("Random - "), style: (fg: "${c3}", modifiers: "Bold")),
                    (kind: Property(Status(Random)), style: (fg: "${c3}", modifiers: "Bold")),
                    (kind: Text("]"), style: (fg: "${c4}", modifiers: "Bold"))
                ],
                center: [
                    (kind: Property(Song(Artist)), style: (fg: "${c3}", modifiers: "Bold"),
                        default: (kind: Text("Unknown"), style: (fg: "${c3}", modifiers: "Bold"))
                    ),
                    (kind: Text(" - ")),
                    (kind: Property(Song(Title)), style: (fg: "${c6}", modifiers: "Bold"),
                        default: (kind: Text("No Song"), style: (fg: "${c6}", modifiers: "Bold"))
                    )
                ],
                right: [
                    (kind: Text("Vol: "), style: (fg: "${c4}", modifiers: "Bold")),
                    (kind: Property(Status(Volume)), style: (fg: "${c4}", modifiers: "Bold")),
                    (kind: Text("% "), style: (fg: "${c4}", modifiers: "Bold"))
                ]
            )
        ],
    ),
)
THEME

    if [[ $? -eq 0 ]]; then
        log "rmpc theme generated successfully at $rmpc_theme"
        return 0
    else
        log "Error: Failed to generate rmpc theme"
        return 1
    fi
}

apply_theme() {
    local wallpaper="$1"
    log "Applying theme based on $(basename "$wallpaper")..."

    # Check if wal is available
    if ! command -v wal &>/dev/null; then
        log "Warning: 'wal' (pywal) not found. Skipping theme generation."
        return 0
    fi

    # Generate colors with wal
    log "Generating color palette with pywal..."
    if ! wal -i "$wallpaper" --saturate 0.7 &>/dev/null; then
        log "Error: Failed to generate colors with wal"
        return 1
    fi

    # Link pywal colors to waybar
    local waybar_config="$HOME/.config/waybar"
    if [[ -f "$HOME/.cache/wal/colors-waybar.css" ]]; then
        mkdir -p "$waybar_config"
        ln -sf "$HOME/.cache/wal/colors-waybar.css" "$waybar_config/colors-waybar.css" &>/dev/null
        log "Linked pywal colors to Waybar"
    fi

    # Reload Waybar (if running)
    if pgrep -x "waybar" >/dev/null 2>&1; then
        log "Reloading Waybar..."
        pkill waybar &>/dev/null
        sleep 1
        if command -v waybar &>/dev/null; then
            waybar &>/dev/null &
            log "Waybar reloaded"
        else
            log "Warning: waybar command not found"
        fi
    else
        log "Waybar is not running, skipping reload"
    fi

    log "Theme colors applied"
    apply_hyprland_borders
    apply_rofi_theme
    apply_rmpc_theme
}

apply_hyprland_borders() {
    local colors_file="$HOME/.cache/wal/colors.json"

    if [[ ! -f $colors_file ]]; then
        log "Warning: colors.json not found. Cannot set Hyprland border colors."
        return 1
    fi

    # Check if jq is available
    if ! command -v jq &>/dev/null; then
        log "Warning: jq not found. Cannot set Hyprland border colors."
        return 1
    fi

    # Extract colors with error checking
    local color1 color2 inactive
    color1=$(jq -r '.colors.color1 // empty' "$colors_file" 2>/dev/null)
    color2=$(jq -r '.colors.color2 // empty' "$colors_file" 2>/dev/null)
    inactive=$(jq -r '.colors.color0 // empty' "$colors_file" 2>/dev/null)

    if [[ -z $color1 || -z $color2 || -z $inactive ]]; then
        log "Warning: Could not extract colors from colors.json"
        return 1
    fi

    log "Setting Hyprland border colors..."

    # Remove # from color codes and validate format
    color1="${color1#\#}"
    color2="${color2#\#}"
    inactive="${inactive#\#}"

    # Validate hex colors (basic check)
    if [[ ! $color1 =~ ^[0-9a-fA-F]{6}$ ]] || [[ ! $color2 =~ ^[0-9a-fA-F]{6}$ ]] || [[ ! $inactive =~ ^[0-9a-fA-F]{6}$ ]]; then
        log "Warning: Invalid color format detected"
        return 1
    fi

    # Apply border colors
    if hyprctl keyword general:col.active_border "rgba(${color1}ee) rgba(${color2}ee) 45deg" &>/dev/null &&
        hyprctl keyword general:col.inactive_border "rgba(${inactive}aa)" &>/dev/null; then
        log "Hyprland border colors applied successfully"
    else
        log "Warning: Failed to apply Hyprland border colors"
        return 1
    fi
}

apply_rofi_theme() {
    local colors_file="$HOME/.cache/wal/colors.json"
    local rofi_config_dir="$HOME/.config/rofi"
    local rofi_theme="$rofi_config_dir/colors-pywal.rasi"

    if [[ ! -f $colors_file ]]; then
        log "Warning: colors.json not found. Cannot generate Rofi theme."
        return 1
    fi

    # Check if jq is available
    if ! command -v jq &>/dev/null; then
        log "Warning: jq not found. Cannot generate Rofi theme."
        return 1
    fi

    log "Generating minimalist Rofi theme from pywal colors..."

    # Create rofi config directory if it doesn't exist
    mkdir -p "$rofi_config_dir"

    # Extract colors from wal
    local bg=$(jq -r '.special.background // empty' "$colors_file" 2>/dev/null)
    local fg=$(jq -r '.special.foreground // empty' "$colors_file" 2>/dev/null)
    local c0=$(jq -r '.colors.color0 // empty' "$colors_file" 2>/dev/null)
    local c4=$(jq -r '.colors.color4 // empty' "$colors_file" 2>/dev/null)
    local c8=$(jq -r '.colors.color8 // empty' "$colors_file" 2>/dev/null)

    # Validate colors
    if [[ -z $bg || -z $fg ]]; then
        log "Warning: Could not extract colors from colors.json"
        return 1
    fi

    # Generate minimalist block-style Rofi theme
    cat >"$rofi_theme" <<EOF
* {
    background:     ${bg};
    background-alt: ${c0};
    foreground:     ${fg};
    selected:       ${c4};
    border:         ${c8};
    
    background-color: transparent;
    text-color: @foreground;
    font: "JetBrains Mono 11";
}

window {
    background-color: @background;
    border: 1px;
    border-color: @border;
    padding: 0px;
    width: 600px;
}

mainbox {
    background-color: transparent;
    children: [ inputbar, listview ];
    spacing: 0px;
    padding: 0px;
}

inputbar {
    background-color: @background-alt;
    children: [ prompt, entry ];
    padding: 12px;
    spacing: 8px;
}

prompt {
    background-color: transparent;
    text-color: @selected;
    padding: 0px;
}

entry {
    background-color: transparent;
    text-color: @foreground;
    placeholder: "";
}

listview {
    background-color: transparent;
    scrollbar: false;
    spacing: 0px;
    lines: 8;
    padding: 0px;
}

element {
    background-color: transparent;
    text-color: @foreground;
    padding: 5px;
    spacing: 0px;
}

element selected {
    background-color: @selected;
    text-color: @background;
}

element-text {
    background-color: transparent;
    text-color: inherit;
}
EOF

    if [[ $? -eq 0 ]]; then
        log "Rofi theme generated successfully at $rofi_theme"

        # Update Rofi config to use the new theme
        local rofi_config="$rofi_config_dir/config.rasi"

        # Check if config exists and update it, or create a new one
        if [[ -f $rofi_config ]]; then
            # Check if @theme directive exists
            if grep -q "^@theme" "$rofi_config"; then
                # Replace existing theme
                sed -i "s|^@theme.*|@theme \"$rofi_theme\"|" "$rofi_config"
                log "Updated Rofi config to use pywal theme"
            else
                # Add theme directive at the top
                sed -i "1i@theme \"$rofi_theme\"" "$rofi_config"
                log "Added pywal theme to Rofi config"
            fi
        else
            # Create new config with theme
            cat >"$rofi_config" <<EOF
@theme "$rofi_theme"
configuration {
    font: "JetBrains Mono 11";
    show-icons: false;
    display-drun: "";
    display-run: "";
    display-window: "";
    drun-display-format: "{name}";
}
EOF
            log "Created new Rofi config with pywal theme"
        fi

        return 0
    else
        log "Error: Failed to generate Rofi theme"
        return 1
    fi
}

# Signal handling for clean exit
trap 'log "Script interrupted"; exit 1' INT TERM

# Main execution
log "Starting wallpaper setup script..."

# Handle wallpaper selection
if [[ -z $WALLPAPER ]]; then
    choose_random_wallpaper
else
    log "Resolving wallpaper path for: $WALLPAPER"
    if ! WALLPAPER=$(resolve_wallpaper_path "$WALLPAPER"); then
        log "Error: Could not resolve wallpaper path: $1"
        log "Make sure the file exists or try using an absolute path"
        exit 1
    fi
    log "Resolved wallpaper path: $WALLPAPER"

    if [[ ! -f $WALLPAPER ]]; then
        log "Error: Wallpaper file not found -> $WALLPAPER"
        log "Please check the file path and try again"
        exit 1
    fi
fi

# Ensure hyprpaper is running
start_hyprpaper

# Set the wallpaper
set_wallpaper "$WALLPAPER"

# Apply the theme
apply_theme "$WALLPAPER"

log "Wallpaper and theme setup completed successfully!"
