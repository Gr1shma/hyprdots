#!/usr/bin/env bash

op=$(printf ' Poweroff\n Reboot\n Lock\n Logout' |
    fzf --reverse --no-scrollbar --padding 1,3 --prompt 'Power Menu: ' |
    awk '{print tolower($2)}')

[[ -z "$op" ]] && exit 0

case $op in
poweroff) systemctl poweroff ;;
reboot) systemctl reboot ;;
lock)
    (
        sleep 0.5s
        hyprlock
    ) &
    disown
    ;;
logout) hyprctl dispatch exit ;;
esac
