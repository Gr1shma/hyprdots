#!/bin/bash

# Media Tracker CLI Application
# Saves data to ~/dox/media-tracker/

TRACKER_DIR="$HOME/dox/media-tracker"
MANGA_FILE="$TRACKER_DIR/manga.csv"
ANIME_FILE="$TRACKER_DIR/anime.csv"
SERIES_FILE="$TRACKER_DIR/series.csv"
FILM_FILE="$TRACKER_DIR/film.csv"

# Create directory and files if they don't exist
mkdir -p "$TRACKER_DIR"

# Initialize CSV files with headers if they don't exist
[ ! -f "$MANGA_FILE" ] && echo "name,type,number,date_added,last_updated" >"$MANGA_FILE"
[ ! -f "$ANIME_FILE" ] && echo "name,season,episode,date_added,last_updated" >"$ANIME_FILE"
[ ! -f "$SERIES_FILE" ] && echo "name,season,episode,date_added,last_updated" >"$SERIES_FILE"
[ ! -f "$FILM_FILE" ] && echo "name,date_watched" >"$FILM_FILE"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# Utility function to get current date
get_date() {
	date +%Y-%m-%d
}

# Function to add manga
add_manga() {
	echo -e "${BLUE}=== Add New Manga ===${NC}"
	read -p "Enter manga name: " name

	if [ -z "$name" ]; then
		echo -e "${RED}Error: Name cannot be empty${NC}"
		return 1
	fi

	# Check if manga already exists
	if grep -qi "^$name," "$MANGA_FILE"; then
		echo -e "${RED}Error: '$name' already exists${NC}"
		return 1
	fi

	read -p "Track by (1) Chapter or (2) Volume? [1/2]: " track_type

	case $track_type in
	1)
		read -p "Starting chapter [default: 1]: " num
		num=${num:-1}
		type="ch"
		;;
	2)
		read -p "Starting volume [default: 1]: " num
		num=${num:-1}
		type="vol"
		;;
	*)
		num=1
		type="ch"
		;;
	esac

	current_date=$(get_date)
	echo "$name,$type,$num,$current_date,$current_date" >>"$MANGA_FILE"
	echo -e "${GREEN}Added: $name $type-$num${NC}"
}

# Function to add anime
add_anime() {
	echo -e "${BLUE}=== Add New Anime ===${NC}"
	read -p "Enter anime name: " name

	if [ -z "$name" ]; then
		echo -e "${RED}Error: Name cannot be empty${NC}"
		return 1
	fi

	if grep -qi "^$name," "$ANIME_FILE"; then
		echo -e "${RED}Error: '$name' already exists${NC}"
		return 1
	fi

	read -p "Starting season [default: 1]: " season
	season=${season:-1}
	read -p "Starting episode [default: 1]: " episode
	episode=${episode:-1}

	current_date=$(get_date)
	echo "$name,$season,$episode,$current_date,$current_date" >>"$ANIME_FILE"
	echo -e "${GREEN}Added: $name S${season}E${episode}${NC}"
}

# Function to add series
add_series() {
	echo -e "${BLUE}=== Add New Series ===${NC}"
	read -p "Enter series name: " name

	if [ -z "$name" ]; then
		echo -e "${RED}Error: Name cannot be empty${NC}"
		return 1
	fi

	if grep -qi "^$name," "$SERIES_FILE"; then
		echo -e "${RED}Error: '$name' already exists${NC}"
		return 1
	fi

	read -p "Starting season [default: 1]: " season
	season=${season:-1}
	read -p "Starting episode [default: 1]: " episode
	episode=${episode:-1}

	current_date=$(get_date)
	echo "$name,$season,$episode,$current_date,$current_date" >>"$SERIES_FILE"
	echo -e "${GREEN}Added: $name S${season}E${episode}${NC}"
}

# Function to add film
add_film() {
	echo -e "${BLUE}=== Add Watched Film ===${NC}"
	read -p "Enter film name: " name

	if [ -z "$name" ]; then
		echo -e "${RED}Error: Name cannot be empty${NC}"
		return 1
	fi

	read -p "Date watched [YYYY-MM-DD] (press Enter for today): " date_watched
	date_watched=${date_watched:-$(get_date)}

	# Validate date format
	if ! date -d "$date_watched" &>/dev/null; then
		echo -e "${RED}Error: Invalid date format${NC}"
		return 1
	fi

	echo "$name,$date_watched" >>"$FILM_FILE"
	echo -e "${GREEN}Added: $name (watched on $date_watched)${NC}"
}

# Function to display manga in fzf format
display_manga() {
	tail -n +2 "$MANGA_FILE" | while IFS=, read -r name type num date_added last_updated; do
		echo "$name | $type-$num | Added: $date_added | Updated: $last_updated"
	done
}

# Function to display anime in fzf format
display_anime() {
	tail -n +2 "$ANIME_FILE" | while IFS=, read -r name season episode date_added last_updated; do
		echo "$name | S${season}E${episode} | Added: $date_added | Updated: $last_updated"
	done
}

# Function to display series in fzf format
display_series() {
	tail -n +2 "$SERIES_FILE" | while IFS=, read -r name season episode date_added last_updated; do
		echo "$name | S${season}E${episode} | Added: $date_added | Updated: $last_updated"
	done
}

# Function to display films in fzf format
display_films() {
	tail -n +2 "$FILM_FILE" | while IFS=, read -r name date_watched; do
		echo "$name | Watched: $date_watched"
	done
}

# Function to update manga progress
update_manga() {
	local display_line="$1"
	local action="$2"

	# Extract name from display line
	name=$(echo "$display_line" | cut -d'|' -f1 | xargs)

	# Find the line in CSV
	line=$(grep -i "^$name," "$MANGA_FILE")
	if [ -z "$line" ]; then
		echo -e "${RED}Error: Entry not found${NC}"
		return 1
	fi

	IFS=, read -r csv_name type num date_added last_updated <<<"$line"

	case $action in
	increase)
		new_num=$((num + 1))
		new_name="$csv_name"
		new_date_added="$date_added"
		;;
	decrease)
		new_num=$((num - 1))
		[ $new_num -lt 1 ] && new_num=1
		new_name="$csv_name"
		new_date_added="$date_added"
		;;
	edit)
		echo -e "${CYAN}=== Edit Manga ===${NC}"

		# Edit submenu
		while true; do
			edit_choice=$(echo -e "Edit Name\nEdit $type Number\nEdit Date Added\nDone" | fzf \
				--prompt="Edit > " \
				--header="Current: $csv_name | $type-$num | Added: $date_added" \
				--height=40% \
				--border)

			case $edit_choice in
			"Edit Name")
				read -p "Enter new name [$csv_name]: " input_name
				if [ -n "$input_name" ]; then
					csv_name="$input_name"
				fi
				;;
			"Edit $type Number")
				read -p "Enter new $type number [$num]: " input_num
				if [[ $input_num =~ ^[0-9]+$ ]] && [ "$input_num" -ge 1 ]; then
					num="$input_num"
				else
					echo -e "${RED}Invalid number${NC}"
				fi
				;;
			"Edit Date Added")
				read -p "Enter new date [YYYY-MM-DD] [$date_added]: " input_date
				if [ -n "$input_date" ]; then
					if date -d "$input_date" &>/dev/null; then
						date_added="$input_date"
					else
						echo -e "${RED}Invalid date format${NC}"
					fi
				fi
				;;
			"Done" | "")
				break
				;;
			esac
		done

		new_name="$csv_name"
		new_num="$num"
		new_date_added="$date_added"
		;;
	*)
		return 1
		;;
	esac

	current_date=$(get_date)
	# Delete old entry and add new one
	sed -i "\|^$name,$type,|d" "$MANGA_FILE"
	echo "$new_name,$type,$new_num,$new_date_added,$current_date" >>"$MANGA_FILE"
	echo -e "${GREEN}Updated: $new_name $type-$new_num${NC}"
}

# Function to update anime/series progress
update_episode() {
	local display_line="$1"
	local action="$2"
	local file="$3"

	name=$(echo "$display_line" | cut -d'|' -f1 | xargs)
	line=$(grep -i "^$name," "$file")

	if [ -z "$line" ]; then
		echo -e "${RED}Error: Entry not found${NC}"
		return 1
	fi

	IFS=, read -r csv_name season episode date_added last_updated <<<"$line"

	case $action in
	"next episode")
		new_episode=$((episode + 1))
		new_season=$season
		new_name="$csv_name"
		new_date_added="$date_added"
		;;
	"prev episode")
		new_episode=$((episode - 1))
		new_season=$season
		if [ $new_episode -lt 1 ]; then
			new_episode=1
		fi
		new_name="$csv_name"
		new_date_added="$date_added"
		;;
	"next season")
		new_season=$((season + 1))
		new_episode=1
		new_name="$csv_name"
		new_date_added="$date_added"
		;;
	"prev season")
		new_season=$((season - 1))
		new_episode=$episode
		if [ $new_season -lt 1 ]; then
			new_season=1
		fi
		new_name="$csv_name"
		new_date_added="$date_added"
		;;
	"edit")
		echo -e "${CYAN}=== Edit Entry ===${NC}"

		# Edit submenu
		while true; do
			edit_choice=$(echo -e "Edit Name\nEdit Season\nEdit Episode\nEdit Date Added\nDone" | fzf \
				--prompt="Edit > " \
				--header="Current: $csv_name | S${season}E${episode} | Added: $date_added" \
				--height=40% \
				--border)

			case $edit_choice in
			"Edit Name")
				read -p "Enter new name [$csv_name]: " input_name
				if [ -n "$input_name" ]; then
					csv_name="$input_name"
				fi
				;;
			"Edit Season")
				read -p "Enter new season [$season]: " input_season
				if [[ $input_season =~ ^[0-9]+$ ]] && [ "$input_season" -ge 1 ]; then
					season="$input_season"
				else
					echo -e "${RED}Invalid season number${NC}"
				fi
				;;
			"Edit Episode")
				read -p "Enter new episode [$episode]: " input_episode
				if [[ $input_episode =~ ^[0-9]+$ ]] && [ "$input_episode" -ge 1 ]; then
					episode="$input_episode"
				else
					echo -e "${RED}Invalid episode number${NC}"
				fi
				;;
			"Edit Date Added")
				read -p "Enter new date [YYYY-MM-DD] [$date_added]: " input_date
				if [ -n "$input_date" ]; then
					if date -d "$input_date" &>/dev/null; then
						date_added="$input_date"
					else
						echo -e "${RED}Invalid date format${NC}"
					fi
				fi
				;;
			"Done" | "")
				break
				;;
			esac
		done

		new_name="$csv_name"
		new_season="$season"
		new_episode="$episode"
		new_date_added="$date_added"
		;;
	*)
		return 1
		;;
	esac

	current_date=$(get_date)
	# Delete old entry and add new one
	sed -i "\|^$name,$season,$episode,|d" "$file"
	echo "$new_name,$new_season,$new_episode,$new_date_added,$current_date" >>"$file"
	echo -e "${GREEN}Updated: $new_name S${new_season}E${new_episode}${NC}"
}

# Function to delete entry
delete_entry() {
	local display_line="$1"
	local file="$2"

	name=$(echo "$display_line" | cut -d'|' -f1 | xargs)

	read -p "Delete '$name'? [y/N]: " confirm
	if [[ $confirm =~ ^[Yy]$ ]]; then
		sed -i "\|^$name,|d" "$file"
		echo -e "${GREEN}Deleted: $name${NC}"
	fi
}

# Function to edit film
edit_film() {
	local display_line="$1"

	name=$(echo "$display_line" | cut -d'|' -f1 | xargs)
	line=$(grep -i "^$name," "$FILM_FILE")

	if [ -z "$line" ]; then
		echo -e "${RED}Error: Entry not found${NC}"
		return 1
	fi

	IFS=, read -r csv_name date_watched <<<"$line"

	echo -e "${CYAN}=== Edit Film ===${NC}"

	# Edit submenu
	while true; do
		edit_choice=$(echo -e "Edit Name\nEdit Date Watched\nDone" | fzf \
			--prompt="Edit > " \
			--header="Current: $csv_name | Watched: $date_watched" \
			--height=40% \
			--border)

		case $edit_choice in
		"Edit Name")
			read -p "Enter new name [$csv_name]: " input_name
			if [ -n "$input_name" ]; then
				csv_name="$input_name"
			fi
			;;
		"Edit Date Watched")
			read -p "Enter new date [YYYY-MM-DD] [$date_watched]: " input_date
			if [ -n "$input_date" ]; then
				if date -d "$input_date" &>/dev/null; then
					date_watched="$input_date"
				else
					echo -e "${RED}Invalid date format${NC}"
				fi
			fi
			;;
		"Done" | "")
			break
			;;
		esac
	done

	# Delete old entry and add new one
	sed -i "\|^$name,|d" "$FILM_FILE"
	echo "$csv_name,$date_watched" >>"$FILM_FILE"
	echo -e "${GREEN}Updated: $csv_name${NC}"
}

# Manga menu
manga_menu() {
	while true; do
		options="[+ Add New Manga]\n[← Back]\n"
		manga_list=$(display_manga)
		[ -n "$manga_list" ] && options+="$manga_list"

		selected=$(echo -e "$options" | fzf \
			--prompt="Manga > " \
			--header="Select manga to manage" \
			--height=70% \
			--border)

		[ -z "$selected" ] && return

		if [ "$selected" = "[+ Add New Manga]" ]; then
			add_manga
			sleep 1
		elif [ "$selected" = "[← Back]" ]; then
			return
		else
			# Extract and display detailed info
			name=$(echo "$selected" | cut -d'|' -f1 | xargs)

			# Stay in action menu until user chooses Back or Delete
			while true; do
				line=$(grep -i "^$name," "$MANGA_FILE")
				if [ -z "$line" ]; then
					break
				fi

				IFS=, read -r csv_name type num date_added last_updated <<<"$line"

				header="$csv_name | Progress: $type-$num | Added: $date_added | Updated: $last_updated"

				action=$(echo -e "Increase\nDecrease\nEdit\nDelete\nBack" | fzf \
					--prompt="Action > " \
					--header="$header" \
					--height=40% \
					--border)

				case $action in
				Increase) update_manga "$selected" "increase" ;;
				Decrease) update_manga "$selected" "decrease" ;;
				Edit) update_manga "$selected" "edit" ;;
				Delete)
					delete_entry "$selected" "$MANGA_FILE"
					break
					;;
				*) break ;;
				esac
			done
		fi
	done
}

# Anime menu
anime_menu() {
	while true; do
		options="[+ Add New Anime]\n[← Back]\n"
		anime_list=$(display_anime)
		[ -n "$anime_list" ] && options+="$anime_list"

		selected=$(echo -e "$options" | fzf \
			--prompt="Anime > " \
			--header="Select anime to manage" \
			--height=70% \
			--border)

		[ -z "$selected" ] && return

		if [ "$selected" = "[+ Add New Anime]" ]; then
			add_anime
			sleep 1
		elif [ "$selected" = "[← Back]" ]; then
			return
		else
			# Extract and display detailed info
			name=$(echo "$selected" | cut -d'|' -f1 | xargs)

			# Stay in action menu until user chooses Back or Delete
			while true; do
				line=$(grep -i "^$name," "$ANIME_FILE")
				if [ -z "$line" ]; then
					break
				fi

				IFS=, read -r csv_name season episode date_added last_updated <<<"$line"

				header="$csv_name | S${season}E${episode} | Added: $date_added | Updated: $last_updated"

				action=$(echo -e "Next Episode\nPrev Episode\nNext Season\nPrev Season\nEdit\nDelete\nBack" | fzf \
					--prompt="Action > " \
					--header="$header" \
					--height=40% \
					--border)

				case $action in
				"Next Episode") update_episode "$selected" "next episode" "$ANIME_FILE" ;;
				"Prev Episode") update_episode "$selected" "prev episode" "$ANIME_FILE" ;;
				"Next Season") update_episode "$selected" "next season" "$ANIME_FILE" ;;
				"Prev Season") update_episode "$selected" "prev season" "$ANIME_FILE" ;;
				Edit) update_episode "$selected" "edit" "$ANIME_FILE" ;;
				Delete)
					delete_entry "$selected" "$ANIME_FILE"
					break
					;;
				*) break ;;
				esac
			done
		fi
	done
}

# Series menu
series_menu() {
	while true; do
		options="[+ Add New Series]\n[← Back]\n"
		series_list=$(display_series)
		[ -n "$series_list" ] && options+="$series_list"

		selected=$(echo -e "$options" | fzf \
			--prompt="Series > " \
			--header="Select series to manage" \
			--height=70% \
			--border)

		[ -z "$selected" ] && return

		if [ "$selected" = "[+ Add New Series]" ]; then
			add_series
			sleep 1
		elif [ "$selected" = "[← Back]" ]; then
			return
		else
			# Extract and display detailed info
			name=$(echo "$selected" | cut -d'|' -f1 | xargs)

			# Stay in action menu until user chooses Back or Delete
			while true; do
				line=$(grep -i "^$name," "$SERIES_FILE")
				if [ -z "$line" ]; then
					break
				fi

				IFS=, read -r csv_name season episode date_added last_updated <<<"$line"

				header="$csv_name | S${season}E${episode} | Added: $date_added | Updated: $last_updated"

				action=$(echo -e "Next Episode\nPrev Episode\nNext Season\nPrev Season\nEdit\nDelete\nBack" | fzf \
					--prompt="Action > " \
					--header="$header" \
					--height=40% \
					--border)

				case $action in
				"Next Episode") update_episode "$selected" "next episode" "$SERIES_FILE" ;;
				"Prev Episode") update_episode "$selected" "prev episode" "$SERIES_FILE" ;;
				"Next Season") update_episode "$selected" "next season" "$SERIES_FILE" ;;
				"Prev Season") update_episode "$selected" "prev season" "$SERIES_FILE" ;;
				Edit) update_episode "$selected" "edit" "$SERIES_FILE" ;;
				Delete)
					delete_entry "$selected" "$SERIES_FILE"
					break
					;;
				*) break ;;
				esac
			done
		fi
	done
}

# Film menu
film_menu() {
	while true; do
		options="[+ Add Watched Film]\n[← Back]\n"
		film_list=$(display_films)
		[ -n "$film_list" ] && options+="$film_list"

		selected=$(echo -e "$options" | fzf \
			--prompt="Films > " \
			--header="Select film to manage" \
			--height=70% \
			--border)

		[ -z "$selected" ] && return

		if [ "$selected" = "[+ Add Watched Film]" ]; then
			add_film
			sleep 1
		elif [ "$selected" = "[← Back]" ]; then
			return
		else
			# Extract and display detailed info
			name=$(echo "$selected" | cut -d'|' -f1 | xargs)

			# Stay in action menu until user chooses Back or Delete
			while true; do
				line=$(grep -i "^$name," "$FILM_FILE")
				if [ -z "$line" ]; then
					break
				fi

				IFS=, read -r csv_name date_watched <<<"$line"

				header="$csv_name | Watched: $date_watched"

				action=$(echo -e "Edit\nDelete\nBack" | fzf \
					--prompt="Action > " \
					--header="$header" \
					--height=40% \
					--border)

				case $action in
				Edit) edit_film "$selected" ;;
				Delete)
					delete_entry "$selected" "$FILM_FILE"
					break
					;;
				*) break ;;
				esac
			done
		fi
	done
}

# Main menu
main_menu() {
	if ! command -v fzf &>/dev/null; then
		echo -e "${RED}Error: fzf is not installed${NC}"
		echo "Install: sudo apt install fzf (Ubuntu) or brew install fzf (macOS)"
		exit 1
	fi

	while true; do
		selected=$(echo -e "Manga\nAnime\nSeries\nFilms\nQuit" | fzf \
			--prompt="Media Tracker > " \
			--header="Select media type" \
			--height=40% \
			--border \
			--ansi)

		case $selected in
		"Manga") manga_menu ;;
		"Anime") anime_menu ;;
		"Series") series_menu ;;
		"Films") film_menu ;;
		"Quit" | "")
			echo -e "${BLUE}Goodbye!${NC}"
			exit 0
			;;
		esac
	done
}

main_menu
