#!/usr/bin/env zsh

NOTES_DIR="$HOME/dox/abstract"

notes=$(find "$NOTES_DIR" -type f -name "*.md" ! -name "*template*" -printf "%P\n" | sort)

selected=$(printf "[Create New Note]\n%s" "$notes" | fzf --prompt="Select note: ")

if [[ -z $selected ]]; then
	exit 0
fi

if [[ $selected == "[Create New Note]" ]]; then
	echo -n "Enter note name (use / for folders): "
	read note_name

	if [[ -z $note_name ]]; then
		echo "No name provided. Exiting."
		exit 1
	fi

	if [[ ! $note_name =~ \.md$ ]]; then
		note_name="${note_name}.md"
	fi

	note_file="$NOTES_DIR/$note_name"

	note_dir=$(dirname "$note_file")
	if [[ ! -d $note_dir ]]; then
		mkdir -p "$note_dir"
	fi
else
	note_file="$NOTES_DIR/$selected"

	if [[ ! -f $note_file ]]; then
		echo "File not found: $note_file"
		exit 1
	fi
fi

nvim "$note_file"
